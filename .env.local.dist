# Lokale Entwicklung – Kopie nach .env.local, NICHT committen
APP_ENV=dev
APP_SECRET=dev_secret_not_for_production

# Lokale DB (z.B. direkt PostgreSQL auf localhost)
DB_PASSWORD=changeme
DATABASE_URL="postgresql://app:changeme@127.0.0.1:5432/app?serverVersion=17&charset=utf8"

# Mock-Provider für lokale Entwicklung ohne GPU
LLM_PROVIDER=mock

# HuggingFace Token (nur auf VM benötigt)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
