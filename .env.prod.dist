# Produktions-Umgebung auf der A100-VM
# Kopieren nach .env.local auf der VM – NICHT committen!
#
# Verwendung:
#   docker compose --env-file .env --env-file .env.local -f docker-compose.yml -f docker-compose.llama-70b.yml up -d

# Pflicht
DB_PASSWORD=ein_sicheres_passwort_hier

# LLM-Provider: vllm (nicht mock!)
LLM_PROVIDER=vllm

# Modell-Verzeichnis auf dem Host (wird in den Container gemountet)
HF_CACHE_DIR=/opt/models/huggingface

# Aktives Modell – lokaler Pfad im Container (/root/.cache/huggingface → HF_CACHE_DIR)
# Llama 3.3 70B AWQ:
APP_ACTIVE_MODEL=/root/.cache/huggingface/llama-3.3-70b-awq
MODEL_ID=/root/.cache/huggingface/llama-3.3-70b-awq

# Alternativ Ministral 3 14B:
# APP_ACTIVE_MODEL=/root/.cache/huggingface/ministral-3-14b
# MODEL_ID=/root/.cache/huggingface/ministral-3-14b

# Alternativ Qwen3-Coder-Next AWQ:
# APP_ACTIVE_MODEL=/root/.cache/huggingface/qwen3-coder-next-awq
# MODEL_ID=/root/.cache/huggingface/qwen3-coder-next-awq

# Prompt-Version
PROMPT_VERSION=v1.0

# HF_TOKEN nicht nötig – Modelle sind bereits lokal vorhanden
# HF_TOKEN=
