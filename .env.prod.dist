# Produktions-Umgebung auf der A100-VM
# Kopie nach .env auf der VM, NICHT committen
DB_PASSWORD=ein_sicheres_passwort_hier
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HF_CACHE_DIR=/opt/models/huggingface

# Modell-Konfiguration (Standard: Llama 3.3 70B AWQ)
MODEL_ID=casperhansen/llama-3.3-70b-instruct-awq
GPU_MEM_UTIL=0.95
MAX_MODEL_LEN=8192

LLM_PROVIDER=vllm
PROMPT_VERSION=v1.0
